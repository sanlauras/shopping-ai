# このファイルをコピーして .env.local を作り、実際の値を入力してください。
# 例: cp .env.example .env.local
#
# .env.local はGitには含まれません(.gitignoreで除外済み)。
# Vercelにデプロイする場合は、Vercelのプロジェクト設定 > Environment Variables に
# 同じ名前・値を登録してください。

# --- Supabase (Phase 2: 商品データの保存・キャッシュ) ---
# Supabaseダッシュボード > Project Settings > API から取得できます。
# SUPABASE_SERVICE_ROLE_KEY は強い権限を持つ秘密鍵なので、サーバー側にのみ設定し、
# 絶対にNEXT_PUBLIC_を付けたり、クライアント側のコードに書いたりしないでください。
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google AI Studio / Gemini (Phase 3: AIによるレビュー解析) ---
# https://aistudio.google.com/apikey で発行できます。
GEMINI_API_KEY=

# --- サイトの公開URL (Phase 6: SEO用メタデータ生成) ---
# 独自ドメインを設定するまでは未設定のままでOK(Vercelの自動URLが使われます)。
NEXT_PUBLIC_SITE_URL=
